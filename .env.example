# ============================================================
#  .env.example  ─  実際の値を入れて ".env" という名前で保存
# ============================================================

# ── Ollama (ngrok 経由) ──────────────────────────────────────
# ngrok で公開した Ollama のベースURL（末尾スラッシュ不要）
OLLAMA_NGROK_URL=http://host.docker.internal:11434

# Ollama にロードされているモデル名
OLLAMA_MODEL=gemma2:9b

# ── WordPress ────────────────────────────────────────────────
# サイトのURL（末尾スラッシュ不要）
WP_URL=https://fukushi-jigyousya.com

# 管理者ユーザー名
WP_USERNAME=admin_fukushi-j

# アプリケーションパスワード
#   取得場所: WordPress管理画面 → ユーザー → プロフィール
#             → 「アプリケーションパスワード」セクション
#   スペース区切りのままでOK（例: xxxx xxxx xxxx xxxx xxxx xxxx）
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
